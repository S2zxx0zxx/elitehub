generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  clerkId   String?  @unique
  name      String?
  handle    String?  @unique
  email     String?  @unique
  emailVerified DateTime?
  image         String?
  photo         String?
  role          String? // Fan or Creator
  bio       String?
  theme     String   @default("dark")
  upiId     String?
  kycStatus         String   @default("pending")
  tickTier          String   @default("none") // none, blue, gold
  subscriptionPrice Float?
  razorpayPlanId    String?
  tags              String[]
  status            String   @default("active") // active, suspended, banned
  createdAt         DateTime @default(now())

  posts         Post[]
  follows       Follow[]       @relation("Follower")
  followers     Follow[]       @relation("Following")
  subscriptions Subscription[] @relation("FanSubscription")
  subscribers   Subscription[] @relation("CreatorSubscription")
  purchases     Purchase[]
  payouts       Payout[]
  subPaymentsMade     SubscriptionPayment[] @relation("FanSubPayments")
  subPaymentsReceived SubscriptionPayment[] @relation("CreatorSubPayments")
  likes         Like[]
  comments      Comment[]
  saves         Save[]
}

model Post {
  id         String   @id @default(uuid())
  creatorId  String
  type       String // photo, video, product
  mediaKey   String
  caption    String?
  tags       String[]
  visibility String // public, private
  price      Float?
  viewCount  Int      @default(0)
  createdAt  DateTime @default(now())

  creator   User       @relation(fields: [creatorId], references: [id])
  purchases Purchase[]
  reports   Report[]
  likes     Like[]
  comments  Comment[]
  saves     Save[]
}

model Follow {
  followerId String
  creatorId  String

  follower User @relation("Follower", fields: [followerId], references: [id])
  creator  User @relation("Following", fields: [creatorId], references: [id])

  @@id([followerId, creatorId])
}

model Subscription {
  id            String    @id @default(uuid())
  fanId         String
  creatorId     String
  razorpaySubId String?
  status        String // active, cancelled, past_due
  startedAt     DateTime  @default(now())
  renewsAt      DateTime?

  fan     User @relation("FanSubscription", fields: [fanId], references: [id])
  creator User @relation("CreatorSubscription", fields: [creatorId], references: [id])
  payments SubscriptionPayment[]
}

model Purchase {
  id                String   @id @default(uuid())
  fanId             String
  postId            String
  amount            Float
  commission        Float
  creatorEarning    Float
  razorpayPaymentId String?
  status            String // pending, completed, failed
  createdAt         DateTime @default(now())

  fan  User @relation(fields: [fanId], references: [id])
  post Post @relation(fields: [postId], references: [id])
}

model SubscriptionPayment {
  id                String   @id @default(uuid())
  fanId             String
  creatorId         String
  subscriptionId    String
  amount            Float
  commission        Float
  creatorEarning    Float
  razorpayPaymentId String
  createdAt         DateTime @default(now())

  fan          User         @relation("FanSubPayments", fields: [fanId], references: [id])
  creator      User         @relation("CreatorSubPayments", fields: [creatorId], references: [id])
  subscription Subscription @relation(fields: [subscriptionId], references: [id])
}

model Payout {
  id          String    @id @default(uuid())
  creatorId   String
  amount      Float
  upiId       String
  status      String // requested, paid
  requestedAt DateTime  @default(now())
  paidAt      DateTime?

  creator User @relation(fields: [creatorId], references: [id])
}

model Report {
  id         String   @id @default(uuid())
  reporterId String
  postId     String
  reason     String
  status     String   @default("open") // open, resolved
  createdAt  DateTime @default(now())

  post Post @relation(fields: [postId], references: [id])
}

model Broadcast {
  id        String   @id @default(uuid())
  title     String
  body      String
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String // promotion, utility, etc.
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Like {
  id        String   @id @default(uuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  post Post @relation(fields: [postId], references: [id])

  @@unique([userId, postId])
}

model Comment {
  id        String   @id @default(uuid())
  userId    String
  postId    String
  text      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  post Post @relation(fields: [postId], references: [id])
}

model Save {
  id        String   @id @default(uuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  post Post @relation(fields: [postId], references: [id])

  @@unique([userId, postId])
}
